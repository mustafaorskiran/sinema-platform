# ─── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── TMDb ──────────────────────────────────────────────────
TMDB_BEARER_TOKEN=your_tmdb_v4_bearer_token
TMDB_API_KEY_V3=your_tmdb_v3_api_key

# ─── OpenAI (AI özet, AI öneri, AI sohbet) ───────────────────
OPENAI_API_KEY=your_openai_api_key

# ─── OMDB (kritik puanları — RT/Metacritic/IMDb) ─────────────
OMDB_API_KEY=your_omdb_api_key

# ─── Site URL'leri ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Web Push (VAPID) ──────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:you@example.com

# ─── Resend (e-posta gönderimi) ───────────────────────────
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=bildirim@sinezon.com

# ─── Rate limiting (Upstash Redis) — boş bırakılırsa in-memory fallback kullanılır ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── İç servisler arası kimlik doğrulama ───────────────────
INTERNAL_API_KEY=your_internal_api_key
CRON_SECRET=your_cron_secret

# ─── AdSense (opsiyonel) ───────────────────────────────────
NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_ADSENSE_SLOT_1=
NEXT_PUBLIC_ADSENSE_SLOT_2=
